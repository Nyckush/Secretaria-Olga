@startuml SistemaAcademico

!define PRIMARY_KEY(x) <color:red><b>PK: x</b></color>
!define FOREIGN_KEY(x) <color:blue><b>FK: x</b></color>

entity "anexos" as anexos {
  PRIMARY_KEY(id) : bigint
  nombre : varchar(100) [UNIQUE]
  created_at : timestamp
  updated_at : timestamp
}

entity "cursos" as cursos {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(anexo_id) : bigint
  nombre : varchar(100)
  division : varchar(10)
  turno : enum(Mañana, Tarde, Noche)
  ciclo_lectivo : year
  created_at : timestamp
  updated_at : timestamp
}

entity "etapas" as etapas {
  PRIMARY_KEY(id) : bigint
  nombre : varchar(50)
  orden : tinyint
}

entity "curso_etapa" as curso_etapa {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(curso_id) : bigint
  FOREIGN_KEY(etapa_id) : bigint
  FOREIGN_KEY(modulo_id) : bigint [NULL]
  created_at : timestamp
  updated_at : timestamp
}

entity "curso_materia" as curso_materia {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(curso_id) : bigint
  FOREIGN_KEY(materia_id) : bigint
  nro_cupof : int [UNIQUE]
  created_at : timestamp
  updated_at : timestamp
}

entity "curso_etapa_materia" as curso_etapa_materia {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(curso_etapa_id) : bigint
  FOREIGN_KEY(curso_materia_id) : bigint
  created_at : timestamp
  updated_at : timestamp
}

entity "modulos" as modulos {
  PRIMARY_KEY(id) : bigint
  nombre : varchar(255)
  cursado : tinyint (1, 2, 3)
  horas_total : int [default 30]
  created_at : timestamp
  updated_at : timestamp
}

entity "materias" as materias {
  PRIMARY_KEY(id) : bigint
  nombre : varchar(150)
  horas_semanales : int [default 3]
  FOREIGN_KEY(modulo_id) : bigint
  created_at : timestamp
  updated_at : timestamp
}

entity "docentes" as docentes {
  PRIMARY_KEY(id) : bigint
  nombre : varchar(100) [NULL]
  apellido : varchar(100)
  email : varchar(100) [UNIQUE, NULL]
  telefono : varchar(20) [NULL]
  direccion : varchar(255) [NULL]
  dni : varchar(8) [UNIQUE]
  cuil : varchar(11) [UNIQUE]
  created_at : timestamp
  updated_at : timestamp
}

entity "bloques_horarios" as bloques_horarios {
  PRIMARY_KEY(id) : tinyint
  orden : tinyint [UNIQUE]
  hora_inicio : time
  hora_fin : time
}

entity "asignaciones_docentes" as asignaciones_docentes {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(curso_etapa_materia_id) : bigint
  FOREIGN_KEY(docente_id) : bigint
  fecha_desde : date
  hasta : varchar(50)
  created_at : timestamp
  updated_at : timestamp
}

entity "horarios" as horarios {
  PRIMARY_KEY(id) : bigint
  FOREIGN_KEY(curso_etapa_materia_id) : bigint
  FOREIGN_KEY(docente_id) : bigint
  FOREIGN_KEY(bloque_id) : tinyint
  dia_semana : enum(Lunes, Martes, Miércoles, Jueves, Viernes)
  fecha_desde : date
  hasta : varchar(50)
  created_at : timestamp
  updated_at : timestamp
}

' Relaciones
anexos ||--o{ cursos : "tiene"
cursos ||--o{ curso_etapa : "se divide en"
etapas ||--o{ curso_etapa : "define"
modulos ||--o{ curso_etapa : "asigna"
cursos ||--o{ curso_materia : "tiene"
materias ||--o{ curso_materia : "se asigna"
curso_etapa ||--o{ curso_etapa_materia : "incluye"
curso_materia ||--o{ curso_etapa_materia : "pertenece a"
curso_etapa_materia ||--o{ horarios : "tiene"
docentes ||--o{ horarios : "imparte"
bloques_horarios ||--o{ horarios : "define bloque"

modulos ||--o{ materias : "contiene"
curso_etapa_materia ||--o{ asignaciones_docentes : "tiene"
docentes ||--o{ asignaciones_docentes : "es asignado en"

@enduml